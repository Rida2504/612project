# Copy to .env and fill in. .env is gitignored.
# Source this from the deploy scripts:  set -a; source .env; set +a

# ---- Nebius project / network (already discovered) ----
PARENT_ID="project-u00h7vsbpr000hadrn1m0j"
SUBNET_ID="vpcsubnet-u00smn4x2g1c2d2g8w"
NEBIUS_REGION="us-central1"

# ---- VM shape ----
VM_NAME="textworld-vr-vm"
DISK_NAME="textworld-vr-disk"
PLATFORM="gpu-h200-sxm"          # us-central1 has H200; eu-north1 has gpu-h100-sxm
PRESET="1gpu-16vcpu-200gb"
DISK_SIZE_GIB="500"              # 80 GB models + image + scratch + slack
IMAGE_FAMILY="ubuntu22.04-cuda12"  # CUDA 12.4 / driver 550.x — matches our cu121 build

# ---- SSH ----
# Public key uploaded to the VM via cloud-init for the `ubuntu` user.
SSH_PUBKEY_PATH="$HOME/.ssh/id_ed25519.pub"
SSH_KEY_PATH="$HOME/.ssh/id_ed25519"

# ---- App secrets (baked into ~/textworld-vr.env on the VM by setup; never committed) ----
HF_TOKEN=""                      # Required: HuggingFace token w/ FLUX.1-dev + FLUX.1-Fill-dev licenses
S3_BUCKET=""                     # Required: Nebius Object Storage bucket for scenes
S3_ACCESS_KEY_ID=""              # Required
S3_SECRET_ACCESS_KEY=""          # Required
S3_ENDPOINT_URL=""               # Optional; default https://storage.${NEBIUS_REGION}.nebius.cloud
S3_PREFIX="scenes/"
S3_PUBLIC_BASE_URL=""            # Optional: if set, viewer uses unsigned URLs
